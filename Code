# ---------------------------------------------------------------------------
# 2. SCRAPER — pull additional NGOs from a public Wikipedia list
# ---------------------------------------------------------------------------

def scrape_wikipedia_ngos(url: str, limit: int = 10) -> list[dict]:
    """Scrape NGO names and websites from Wikipedia list pages."""
    leads = []
    try:
        resp = requests.get(url, headers=HEADERS, timeout=10)
        resp.raise_for_status()
        soup = BeautifulSoup(resp.text, "html.parser")
        table = soup.find("table", {"class": "wikitable"})
        if not table:
            log.warning("No wikitable found at %s", url)
            return leads
        rows = table.find_all("tr")[1:]
        for row in rows[:limit]:
            cols = row.find_all(["td", "th"])
            if not cols:
                continue
            name = cols[0].get_text(strip=True)
            website = ""
            location = cols[1].get_text(strip=True) if len(cols) > 1 else ""
            # look for external link
            link = cols[0].find("a", href=True)
            if link and link["href"].startswith("http"):
                website = link["href"]
            leads.append({
                "name": name,
                "website": website,
                "location": location,
                "sector": "NGO",
            })
            time.sleep(random.uniform(0.2, 0.5))
    except Exception as exc:
        log.warning("Scraping failed: %s", exc)
    return leads


# ---------------------------------------------------------------------------
# 3. EMAIL GENERATION (bonus feature)
# ---------------------------------------------------------------------------

def generate_email(name: str, website: str) -> str:
    """Generate a probable contact email from org name and domain."""
    domain = ""
    if website:
        match = re.search(r"https?://(?:www\.)?([^/]+)", website)
        if match:
            domain = match.group(1)
    if not domain:
        return ""
    # Normalise org name → slug
    slug = re.sub(r"[^a-z0-9]", "", name.lower())[:12]
    return f"info@{domain}"


# ---------------------------------------------------------------------------
# 4. DATA CLEANING
# ---------------------------------------------------------------------------

def clean_dataframe(df: pd.DataFrame) -> pd.DataFrame:
    """Remove duplicates, normalise text, fill missing values."""
    # Map possible display names → internal names
    col_map = {c: c for c in df.columns}
    col_map.update({
        "Organization Name": "name",
        "Email": "email",
        "Website": "website",
        "Location": "location",
        "Sector": "sector",
        "LinkedIn": "linkedin",
    })
    # Reverse: find internal name for each column
    def _col(alias: str) -> str:
        for c in df.columns:
            if c == alias or col_map.get(c) == alias:
                return c
        return alias

    name_col    = _col("name")
    website_col = _col("website")

    if name_col in df.columns:
        df = df.drop_duplicates(subset=[name_col], keep="first")
    if website_col in df.columns:
        df = df[~((df[website_col].isin(["", "N/A"])) & df.duplicated())]
        df = df.drop_duplicates(subset=[website_col], keep="first")

    # Normalise text columns
    for col in [name_col, _col("location"), _col("sector")]:
        if col in df.columns:
            df[col] = df[col].astype(str).str.strip()
    if name_col in df.columns:
        df[name_col] = df[name_col].str.title()
    if _col("sector") in df.columns:
        df[_col("sector")] = df[_col("sector")].str.title()
    if website_col in df.columns:
        df[website_col] = df[website_col].astype(str).str.strip().str.lower()

    # Fill missing values
    for alias, default in [("website","N/A"),("location","Unknown"),
                            ("sector","General"),("email","N/A"),("linkedin","N/A")]:
        c = _col(alias)
        if c in df.columns:
            df[c] = df[c].replace({"": default, "nan": default})

    df = df.reset_index(drop=True)
    df.index += 1
    return df


# ---------------------------------------------------------------------------
# 5. EXCEL EXPORT with full formatting
# ---------------------------------------------------------------------------

def export_to_excel(df: pd.DataFrame, path: str) -> None:
    """Write cleaned leads to a formatted Excel workbook."""
    with pd.ExcelWriter(path, engine="openpyxl") as writer:
        df.to_excel(writer, sheet_name="Leads", index=True, index_label="S.No")
        df.describe(include="all").to_excel(writer, sheet_name="Summary")

    wb = load_workbook(path)

    # ── Leads sheet formatting ──
    ws = wb["Leads"]

    DARK_TEAL  = "1B4F72"
    LIGHT_TEAL = "D6EAF8"
    ALT_ROW    = "EBF5FB"
    WHITE      = "FFFFFF"
    ACCENT     = "2E86C1"

    header_font  = Font(name="Arial", bold=True, color=WHITE, size=11)
    header_fill  = PatternFill("solid", start_color=DARK_TEAL)
    header_align = Alignment(horizontal="center", vertical="center", wrap_text=True)

    thin = Side(style="thin", color="B0BEC5")
    border = Border(left=thin, right=thin, top=thin, bottom=thin)

    # Style header row
    for cell in ws[1]:
        cell.font   = header_font
        cell.fill   = header_fill
        cell.alignment = header_align
        cell.border = border

    ws.row_dimensions[1].height = 30

    # Alternating row fills + borders
    for i, row in enumerate(ws.iter_rows(min_row=2), start=2):
        fill_color = ALT_ROW if i % 2 == 0 else WHITE
        fill = PatternFill("solid", start_color=fill_color)
        for cell in row:
            cell.fill   = fill
            cell.border = border
            cell.font   = Font(name="Arial", size=10)
            cell.alignment = Alignment(vertical="center", wrap_text=True)
        ws.row_dimensions[i].height = 18

    # Column widths
    col_widths = {"A": 7, "B": 30, "C": 32, "D": 22, "E": 14, "F": 28, "G": 30}
    for col, width in col_widths.items():
        ws.column_dimensions[col].width = width

    # Freeze header row
    ws.freeze_panes = "A2"

    # Add auto-filter
    ws.auto_filter.ref = ws.dimensions

    # ── Summary sheet formatting ──
    ws2 = wb["Summary"]
    for cell in ws2[1]:
        cell.font = Font(name="Arial", bold=True, color=WHITE, size=10)
        cell.fill = PatternFill("solid", start_color=ACCENT)
        cell.alignment = Alignment(horizontal="center")
    for col in ws2.columns:
        ws2.column_dimensions[get_column_letter(col[0].column)].width = 18

    # ── Stats sheet ──
    ws3 = wb.create_sheet("Stats")
    ws3["A1"] = "Lead Collection Report"
    ws3["A1"].font = Font(name="Arial", bold=True, size=14, color=DARK_TEAL)
    ws3["A3"] = "Generated on"
    ws3["B3"] = datetime.now().strftime("%Y-%m-%d %H:%M")
    ws3["A4"] = "Total Leads"
    ws3["B4"] = f"=COUNTA(Leads!B2:B1000)"
    ws3["A5"] = "Unique Sectors"
    sector_col = "Sector" if "Sector" in df.columns else "sector"
    ws3["B5"] = len(df[sector_col].unique())
    ws3["A6"] = "Leads with Email"
    ws3["B6"] = f'=COUNTIF(Leads!F2:F1000,"<>N/A")'
    ws3["A7"] = "Leads with Website"
    ws3["B7"] = f'=COUNTIF(Leads!D2:D1000,"<>N/A")'

    for row in ws3.iter_rows(min_row=3, max_row=7, min_col=1, max_col=2):
        for cell in row:
            cell.font = Font(name="Arial", size=10)
            cell.border = border
        row[0].font = Font(name="Arial", bold=True, size=10)

    ws3.column_dimensions["A"].width = 22
    ws3.column_dimensions["B"].width = 22

    wb.save(path)
    log.info("Saved workbook → %s", path)


