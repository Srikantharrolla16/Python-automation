# ---------------------------------------------------------------------------
# 7. MAIN PIPELINE
# ---------------------------------------------------------------------------

def main():
    log.info("=== Lead Data Collection Started ===")

    # Collect seed data
    leads = list(SEED_LEADS)

    # Scrape additional entries from Wikipedia
    log.info("Scraping additional NGOs from Wikipedia…")
    wiki_url = (
        "https://en.wikipedia.org/wiki/"
        "List_of_international_non-governmental_organizations"
    )
    scraped = scrape_wikipedia_ngos(wiki_url, limit=8)
    if scraped:
        log.info("Scraped %d additional entries", len(scraped))
        leads.extend(scraped)
    else:
        log.info("Wikipedia scrape returned no results; using seed data only.")

    # Build DataFrame
    df = pd.DataFrame(leads)

    # Ensure all required columns exist
    for col in ["name", "website", "location", "sector"]:
        if col not in df.columns:
            df[col] = ""

    # Generate emails (bonus feature)
    df["email"] = df.apply(
        lambda r: generate_email(r["name"], r["website"]), axis=1
    )

    # Add LinkedIn placeholder (would require API for real data)
    df["linkedin"] = df["name"].apply(
        lambda n: f"https://www.linkedin.com/company/"
                  + re.sub(r"[^a-z0-9-]", "-", n.lower()).strip("-")
    )

    # Clean (before renaming columns)
    log.info("Raw entries: %d", len(df))
    df = clean_dataframe(df)

    # Reorder and rename columns
    df = df[["name", "email", "website", "location", "sector", "linkedin"]]
    df.columns = ["Organization Name", "Email", "Website",
                  "Location", "Sector", "LinkedIn"]
    log.info("After cleaning: %d", len(df))

    # Export
    out_path = "/mnt/user-data/outputs/leads_output.xlsx"
    export_to_excel(df, out_path)

    print(f"\n✅ Done! {len(df)} leads saved to: {out_path}")
    print(schedule_info())
    return df


if __name__ == "__main__":
    main()
